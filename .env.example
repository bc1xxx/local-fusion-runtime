# Environment variables for Local Fusion Runtime
# Copy this file to .env and customize

# Provider: ollama (default) or lmstudio
LOCAL_FUSION_PROVIDER=ollama

# Ollama
OLLAMA_BASE_URL=http://localhost:11434

# LM Studio
LMSTUDIO_BASE_URL=http://localhost:1234/v1

# Hardware profile: lite (default, 16 GB) or strong (32 GB)
LOCAL_FUSION_PROFILE=lite

# Default model roles (used by both providers unless LMSTUDIO_* overrides are set)
ROUTER_MODEL=llama3.2:3b
REASONER_MODEL=phi4-mini
CODER_MODEL=qwen3.5:4b
GENERAL_MODEL=gemma3:4b
CRITIC_MODEL=phi4-mini
JUDGE_MODEL=qwen3.5:4b

# Optional LM Studio-specific model name overrides
# Use these if your LM Studio model names differ from Ollama tags.
# Leave empty to fall back to the default ROUTER_MODEL / REASONER_MODEL etc.
LMSTUDIO_ROUTER_MODEL=
LMSTUDIO_REASONER_MODEL=
LMSTUDIO_CODER_MODEL=
LMSTUDIO_GENERAL_MODEL=
LMSTUDIO_CRITIC_MODEL=
LMSTUDIO_JUDGE_MODEL=

# Request timeout in seconds
REQUEST_TIMEOUT_SECONDS=180
